# =============================================================================
# GEMINI API (REQUIRED)
# Get a free API key at: https://aistudio.google.com/apikey
# =============================================================================
GEMINI_API_KEY=your_api_key_here

# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_URL=http://localhost
QDRANT_PORT=6333

# =============================================================================
# Model and Cache Configuration
# =============================================================================
# Hugging Face cache directory for models
HF_HOME=./data/hf_cache

# Device for retrieval model inference: cuda, cpu, or mps (Apple Silicon)
DEVICE=cuda

# Gemini response cache directory (avoids re-billing on repeated queries)
GEMINI_CACHE_DIR=./data/gemini_cache

# =============================================================================
# Data Directories
# =============================================================================
DATA_DIR=./data
INDEX_DIR=./data/indices

# =============================================================================
# Vision Indexing Configuration
# =============================================================================
# Vision indexing batch size (reduce for limited VRAM)
# RTX 3050 Ti (4GB): use 1
# RTX 3080 (10GB): use 2
# RTX 4090 (24GB): use 4
VISION_BATCH_SIZE=1

# Text indexing batch size
TEXT_BATCH_SIZE=64

# =============================================================================
# Generation Settings
# =============================================================================
MAX_NEW_TOKENS=512
TEMPERATURE=0.1
